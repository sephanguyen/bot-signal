# Claude API (Anthropic) — gọi trực tiếp, không qua trung gian
ANTHROPIC_API_KEY=sk-ant-xxx
CLAUDE_MODEL=claude-sonnet-4-20250514

# AI Backend: "anthropic" (direct Claude API) or "zeroclaw" (local agent)
AI_BACKEND=anthropic

# ZeroClaw config (chỉ cần nếu AI_BACKEND=zeroclaw)
# Install: https://github.com/zeroclaw-labs/zeroclaw
ZEROCLAW_BIN=zeroclaw
ZEROCLAW_MODE=cli
ZEROCLAW_GATEWAY_URL=http://127.0.0.1:3000
ZEROCLAW_MODEL=openrouter/auto
ZEROCLAW_TIMEOUT=120
ZEROCLAW_WORKDIR=

# Telegram Bot
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# Binance Symbols
SYMBOLS=BTCUSDT,XAUUSDT,CLUSDT

# Timeframes
TIMEFRAMES=1d,4h,1h

# Dùng Binance Futures API (true/false)
# Futures: fapi.binance.com + fstream.binance.com (WebSocket)
# Spot: api.binance.com + stream.binance.com (WebSocket)
USE_FUTURES=true

# Thresholds
VOLUME_SPIKE_MULTIPLIER=2.0
RSI_OVERBOUGHT=70
RSI_OVERSOLD=30
SIGNAL_CONFIDENCE_MIN=0.6

# Signal Tier System
# STRONG (>=0.6): Full AI analysis + auto track + save DB
# MEDIUM (>=0.35): AI analysis, gửi Telegram để user tự quyết
# WEAK (>=0.2): Chỉ gửi summary, không gọi AI (tiết kiệm token)
TIER_STRONG_MIN=0.6
TIER_MEDIUM_MIN=0.35
TIER_WEAK_MIN=0.2
TIER_NOTIFY_ALL=true

# Data collection interval (seconds)
COLLECT_INTERVAL=60
